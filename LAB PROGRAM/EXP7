import numpy as np

# Columns: Bedrooms, SquareFootage, SalePrice
house_data = np.array([
    [3, 1200, 500000],
    [5, 2000, 900000],
    [4, 1500, 600000],
    [6, 2500, 1200000],
    [2, 1000, 400000]
])

# Filter houses with more than 4 bedrooms
filtered = house_data[house_data[:, 0] > 4]

average_price = np.mean(filtered[:, 2])

print("Houses with >4 Bedrooms:\n", filtered)
print("Average Sale Price:", average_price)
