import pandas as pd
import matplotlib.pyplot as plt
from sklearn.cluster import KMeans

data = pd.DataFrame({
'spent':[100,200,150,400,500],
'items':[2,5,3,8,10]
})

kmeans = KMeans(n_clusters=2)
data['cluster'] = kmeans.fit_predict(data)

plt.scatter(data['spent'],data['items'],c=data['cluster'])
plt.xlabel("Spent")
plt.ylabel("Items")
plt.show()
